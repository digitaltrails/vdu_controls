#!/usr/bin/env bash
# SPDX-FileCopyrightText: 2021-2026 Contributors to vdu_controls <https://github.com/digitaltrails/vdu_controls>
# SPDX-License-Identifier: GPL-3.0-or-later

# Caution: this is run at github by .github/workflows/static.yml

set -euo pipefail

# Defaults: project is current dir, output is ./docs/_build/mkdocs/site (clean out-of-tree)
PROJECT_DIR="${PWD}"
MKDOCS_YML="${PROJECT_DIR}/docs/mkdocs.yml"
INPUT_DIR="${PROJECT_DIR}/docs/_build/mkdocs/input"
OUTPUT_DIR="${PROJECT_DIR}/docs/_build/mkdocs/site"

ASSEMBLE_ONLY=false
SERVE=false
while [[ $# -gt 0 ]]; do
    case "$1" in
        --assemble) ASSEMBLE_ONLY=true; shift;;
        --serve) SERVE=true; shift ;;
        --source) PROJECT_DIR="$2"; shift 2 ;;
        --output) OUTPUT_DIR="$2"; shift 2 ;;
        -h|--help)
            echo "Usage: $0 [--serve|--assemble] [--source PROJECT_DIR] [--output OUTPUT_DIR]"
            echo "  --serve    Test with mkdocs serve instead of mkdocs build"
            echo "  --assemble Assemble the inputs only (useful for testing with --serve)"
            echo "  --source   Project root directory (default: current dir)"
            echo "  --output   Output directory for the final site (default: ./build/site)"
            exit 0
            ;;
        *) echo "Unknown option: $1"; exit 1 ;;
    esac
done

# Convert output dir to absolute path so we can copy to it later
OUTPUT_DIR=$(realpath -m $OUTPUT_DIR)

echo "📂 Project:        $PROJECT_DIR"
echo "📄 MkDocs Spec:    $MKDOCS_YML"
echo "⚙️ MkDocs Input:   $INPUT_DIR"
echo "📦 MkDocs Output:  $OUTPUT_DIR"


# Change to source dir so relative paths work as they did in the workflow
cd "$PROJECT_DIR"

# Prepare the input folder - populating with project assets
mkdir -p "$INPUT_DIR"

# Convert README → index.md by replacing github alerts by mkdoc ones.
sed '/<!-- mkdocs-exclude-start -->/,/<!-- mkdocs-exclude-end -->/d' README.md > "$INPUT_DIR/index.md"
python3 utils/convert_alerts.py "$INPUT_DIR/index.md"

# Add the changelog - so it is searchable
cp CHANGELOG.md "$INPUT_DIR/changelog.md"

# Pull in the help file as the "manual"
cp src/vdu_controls/resources/docs/help.md "$INPUT_DIR/manual.md"

# Create/copy supporting folders/files
mkdir -p "$INPUT_DIR/assets"
cp -r docs/assets/* "$INPUT_DIR/assets/"
cp -r screenshots "$INPUT_DIR/"
cp -r sample-scripts "$INPUT_DIR/"
mkdir -p "$INPUT_DIR/stylesheets"
cp -r docs/stylesheets/* "$INPUT_DIR/stylesheets/"
cp LICENSE.md "$INPUT_DIR/"

# Copy and lighten the icon
cp src/vdu_controls/resources/icons/app/vdu_controls.svg "$INPUT_DIR/assets/"
sed 's/color:#232629;/color:#f3f3f3;/' "$INPUT_DIR/assets/vdu_controls.svg" \
    > "$INPUT_DIR/assets/vdu_controls_light.svg"

if [[ "$ASSEMBLE_ONLY" == true ]]; then
    echo "⚙️ Assembled $INPUT_DIR"
    exit 0
fi

# Option - only create a test server
if [[ "$SERVE" == true ]]; then
    echo "🔥 Starting live server from $INPUT_DIR"
    cd "$INPUT_DIR"
    mkdocs serve --config-file "$MKDOCS_YML"
    exit 0
fi

# Build the site – inside the build dir, using the copied config
mkdocs build \
    --config-file "$MKDOCS_YML" \
    --site-dir "$OUTPUT_DIR" \
    --clean

touch "$OUTPUT_DIR/.nojekyll"


echo "✅ Build complete! Site is at: $OUTPUT_DIR"
echo "🔥 To serve it locally (cd $OUTPUT_DIR; python3 -m http.server)"
